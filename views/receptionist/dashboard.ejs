<%- include('../partials/header') %>
<section class="quick-actions">
  <a class="btn btn-primary" href="/receptionist/patients/new"><i class="fa-solid fa-user-plus"></i> Register Patient</a>
  <a class="btn btn-primary" href="/receptionist/appointments/new"><i class="fa-solid fa-calendar-plus"></i> Book Appointment</a>
  <a class="btn btn-primary" href="/receptionist/admissions/new"><i class="fa-solid fa-bed"></i> Admit Patient</a>
  <a class="btn btn-primary" href="/receptionist/bills/new"><i class="fa-solid fa-receipt"></i> Generate Bill</a>
</section>
<section class="dashboard-grid">
  <div class="panel span-wide">
    <h2>Today's Appointments</h2>
    <table class="table align-middle"><thead><tr><th>Patient</th><th>Doctor</th><th>Time</th><th>Status</th></tr></thead><tbody>
      <% appointments.forEach(item => { %><tr><td><%= item.patient?.name %></td><td><%= item.doctor?.name %></td><td><%= item.time %></td><td><%= item.status %></td></tr><% }) %>
    </tbody></table>
  </div>
  <div class="panel">
    <h2>Rooms</h2>
    <ul class="notice-list"><% rooms.forEach(room => { %><li><i class="fa-solid fa-door-open"></i> <%= room.roomNumber %> - <%= room.status %></li><% }) %></ul>
  </div>
  <div class="panel">
    <h2>Pending Bills</h2>
    <ul class="notice-list"><% bills.forEach(bill => { %><li><i class="fa-solid fa-file-invoice-dollar"></i> <%= bill.patient?.name %> - Rs. <%= bill.dueAmount %></li><% }) %></ul>
  </div>
</section>
<%- include('../partials/footer') %>
