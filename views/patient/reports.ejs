<%- include('../partials/header') %>
<section class="panel">
  <div class="table-responsive">
    <table class="table align-middle">
      <thead><tr><th>Title</th><th>Type</th><th>Doctor</th><th>Date</th><th class="text-end">Actions</th></tr></thead>
      <tbody>
        <% reports.forEach(report => { %>
          <tr>
            <td><%= report.title %></td>
            <td><%= report.reportType %></td>
            <td><%= report.doctor?.name || '-' %></td>
            <td><%= new Date(report.createdAt).toLocaleDateString() %></td>
            <td class="text-end">
              <a class="btn btn-sm btn-outline-success me-1" href="/billing/reports/<%= report._id %>/print" target="_blank"><i class="fa-solid fa-print"></i> Print</a>
              <a class="btn btn-sm btn-outline-primary" href="<%= report.filePath %>" target="_blank"><i class="fa-solid fa-download"></i></a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% if (!reports.length) { %><p class="empty-line">No reports uploaded yet.</p><% } %>
</section>
<%- include('../partials/footer') %>
