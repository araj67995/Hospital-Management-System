<%- include('../partials/header') %>
<section class="panel">
  <div class="panel-head">
    <h2>Appointments</h2>
    <a class="btn btn-primary btn-sm" href="/patient/appointments/new"><i class="fa-solid fa-calendar-plus"></i> Book Appointment</a>
  </div>
  <div class="table-responsive">
    <table class="table align-middle">
      <thead><tr><th>Date</th><th>Time</th><th>Doctor</th><th>Department</th><th>Status</th><th>Notes</th><th class="text-end">OPD Slip</th></tr></thead>
      <tbody>
        <% appointments.forEach(item => { %>
          <tr>
            <td><%= item.date ? new Date(item.date).toLocaleDateString() : '-' %></td>
            <td><%= item.time || '-' %></td>
            <td><%= item.doctor?.name || '-' %></td>
            <td><%= item.department?.name || '-' %></td>
            <td><span class="badge text-bg-primary"><%= item.status %></span></td>
            <td><%= item.notes || '-' %></td>
            <td class="text-end"><a class="btn btn-sm btn-outline-success" href="/billing/appointments/<%= item._id %>/print" target="_blank"><i class="fa-solid fa-print"></i> Print</a></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% if (!appointments.length) { %><p class="empty-line">No appointments found.</p><% } %>
</section>
<%- include('../partials/footer') %>
