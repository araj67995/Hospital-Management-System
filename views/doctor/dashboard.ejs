<%- include('../partials/header') %>
<section class="profile-band doctor-profile">
  <% if (doctor?.profilePhoto) { %>
    <img class="profile-photo" src="<%= doctor.profilePhoto %>" alt="Doctor profile photo">
  <% } else { %>
    <div class="profile-photo placeholder"><i class="fa-solid fa-user-doctor"></i></div>
  <% } %>
  <div>
    <h2><%= doctor?.name || currentUser.name %></h2>
    <p><%= doctor?.specialization || 'Doctor' %><%= doctor?.department?.name ? ' | ' + doctor.department.name : '' %></p>
  </div>
  <a class="btn btn-primary btn-sm" href="/doctor/appointments/new"><i class="fa-solid fa-calendar-plus"></i> Add Appointment</a>
</section>
<section class="dashboard-grid">
  <div class="panel span-wide">
    <div class="panel-head"><h2>Today's Appointments</h2><a class="btn btn-primary btn-sm" href="/doctor/prescriptions/new"><i class="fa-solid fa-prescription"></i> Add Prescription</a></div>
    <div class="table-responsive">
      <table class="table align-middle">
        <thead><tr><th>Patient</th><th>Department</th><th>Time</th><th>Status</th></tr></thead>
        <tbody>
          <% appointments.forEach(item => { %><tr><td><%= item.patient?.name %></td><td><%= item.department?.name %></td><td><%= item.time %></td><td><span class="badge text-bg-primary"><%= item.status %></span></td></tr><% }) %>
        </tbody>
      </table>
    </div>
  </div>
  <div class="panel">
    <h2>Recent Notes</h2>
    <ul class="notice-list">
      <% prescriptions.forEach(rx => { %><li><i class="fa-solid fa-notes-medical"></i> <%= rx.patient?.name %> - <%= rx.diagnosis || 'Prescription' %></li><% }) %>
      <% if (!prescriptions.length) { %><li>No prescriptions yet</li><% } %>
    </ul>
  </div>
</section>
<%- include('../partials/footer') %>
