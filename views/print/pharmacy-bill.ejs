<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet">
  <link href="/css/print-docs.css" rel="stylesheet">
</head>
<body>

  <!-- Sticky Top Preview Actions -->
  <div class="no-print-bar">
    <div>
      <span class="fw-bold"><i class="fa-solid fa-file-invoice"></i> Medicine Shop Invoice Preview</span>
      <small class="text-muted ms-2">A4 Optimized Layout</small>
    </div>
    <div>
      <button class="btn btn-outline-secondary btn-sm me-2" onclick="window.history.back()"><i class="fa-solid fa-arrow-left"></i> Back</button>
      <button class="btn btn-primary btn-sm" onclick="window.print()"><i class="fa-solid fa-print"></i> Print Document</button>
    </div>
  </div>

  <div class="document-preview-container">
    <div class="a4-document">
      <div class="hospital-watermark"><%= hospitalName %></div>
      <div class="doc-content">
        
        <!-- Header -->
        <div class="doc-header d-flex justify-content-between align-items-center">
          <div class="d-flex align-items-center">
            <div class="me-3">
              <i class="fa-solid fa-circle-h hospital-logo-icon"></i>
            </div>
            <div>
              <h1 class="hospital-title text-hospital-primary"><%= hospitalName %></h1>
              <p class="hospital-subtitle"><i class="fa-solid fa-location-dot"></i> Sector 62, Noida, Uttar Pradesh - 201301</p>
              <p class="hospital-subtitle"><i class="fa-solid fa-phone"></i> +91 95089 70151 | <i class="fa-solid fa-envelope"></i> contact@carepoint.local</p>
              <p class="hospital-subtitle"><i class="fa-solid fa-globe"></i> www.carepointhospital.local | GSTIN: 09AAACC1206D1ZH</p>
            </div>
          </div>
          <div class="text-end">
            <span class="doc-type-title">Pharmacy Bill</span>
            <div class="barcode-container">
              <div class="barcode-bars"></div>
              <div class="barcode-text"><%= bill.billNo %></div>
            </div>
          </div>
        </div>

        <!-- Meta Info -->
        <div class="row">
          <div class="col-6">
            <div class="meta-box">
              <div class="meta-title">Patient Details</div>
              <div class="meta-grid">
                <div class="meta-item"><span class="meta-label">Patient Name:</span><span class="meta-value"><%= bill.patient?.name || bill.customerName || 'Walk-in Customer' %></span></div>
                <div class="meta-item"><span class="meta-label">UHID (ID):</span><span class="meta-value"><%= bill.patient?.patientId || '-' %></span></div>
                <div class="meta-item"><span class="meta-label">Age / Gender:</span><span class="meta-value"><%= bill.patient ? (bill.patient.age || 'N/A') + ' yrs / ' + (bill.patient.gender || 'N/A') : '-' %></span></div>
                <div class="meta-item"><span class="meta-label">Mobile Number:</span><span class="meta-value"><%= bill.patient?.mobile || bill.customerMobile || '-' %></span></div>
              </div>
            </div>
          </div>
          <div class="col-6">
            <div class="meta-box">
              <div class="meta-title">Invoice Details</div>
              <div class="meta-grid">
                <div class="meta-item"><span class="meta-label">Bill No:</span><span class="meta-value"><%= bill.billNo %></span></div>
                <div class="meta-item"><span class="meta-label">Invoice Date:</span><span class="meta-value"><%= new Date(bill.createdAt).toLocaleDateString() %></span></div>
                <div class="meta-item"><span class="meta-label">Payment Mode:</span><span class="meta-value">Cash / UPI</span></div>
                <div class="meta-item"><span class="meta-label">Status:</span><span class="meta-value"><%= bill.status %></span></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Medicines Table -->
        <table class="table hospital-table align-middle">
          <thead>
            <tr>
              <th style="width: 8%">S.No</th>
              <th>Medicine Name</th>
              <th>Unit Type</th>
              <th>Price Type</th>
              <th class="text-center" style="width: 10%">Qty</th>
              <th class="text-end" style="width: 12%">Rate</th>
              <th class="text-end" style="width: 15%">Amount</th>
            </tr>
          </thead>
          <tbody>
            <% (bill.items || []).forEach((item, index) => { %>
              <tr>
                <td><%= index + 1 %></td>
                <td class="fw-bold text-dark"><%= item.name %></td>
                <td><%= item.unit %></td>
                <td><%= item.priceType === 'piece' ? 'Per Piece' : 'Per Unit' %></td>
                <td class="text-center"><%= item.quantity %></td>
                <td class="text-end">Rs. <%= Number(item.rate || 0).toFixed(2) %></td>
                <td class="text-end fw-bold text-dark">Rs. <%= Number(item.amount || 0).toFixed(2) %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>

        <!-- Summary -->
        <div class="row align-items-start">
          <div class="col-6">
            <div class="d-flex align-items-center">
              <div class="qr-container me-3">
                <img class="qr-image" src="https://api.qrserver.com/v1/create-qr-code/?size=90x90&data=<%= encodeURIComponent('Invoice: ' + bill.billNo + ', Total: Rs. ' + bill.total.toFixed(2)) %>" alt="QR Code" width="90" height="90">
              </div>
              <div style="font-size: 0.75rem; color: #6c757d;">
                <p class="mb-1 fw-bold text-dark">Scan QR to Verify Invoice</p>
                <p class="mb-0">This is a system generated print-out. No physical signature is required under standard Indian IT Act regulations.</p>
              </div>
            </div>
          </div>
          <div class="col-6 summary-container">
            <div class="summary-box">
              <div class="summary-row">
                <span>Subtotal:</span>
                <span class="fw-bold">Rs. <%= Number(bill.subtotal || 0).toFixed(2) %></span>
              </div>
              <div class="summary-row">
                <span>GST (18%):</span>
                <span>Rs. <%= Number(bill.gst || 0).toFixed(2) %></span>
              </div>
              <div class="summary-row">
                <span>Discount (10%):</span>
                <span class="text-success">- Rs. <%= Number(bill.discount || 0).toFixed(2) %></span>
              </div>
              <div class="summary-row total-row">
                <span>Grand Total:</span>
                <span>Rs. <%= Number(bill.total || 0).toFixed(2) %></span>
              </div>
              <div class="summary-row">
                <span>Paid Amount:</span>
                <span class="text-hospital-secondary fw-bold">Rs. <%= Number(bill.paidAmount || 0).toFixed(2) %></span>
              </div>
              <div class="summary-row">
                <span>Due Amount:</span>
                <span class="text-danger fw-bold">Rs. <%= Number(bill.dueAmount || 0).toFixed(2) %></span>
              </div>
            </div>
          </div>
        </div>

        <!-- Verification/Signatures -->
        <div class="doc-verification">
          <div class="signature-box">
            <div class="hospital-seal-box">Seal</div>
            <div class="signature-line">Hospital Seal</div>
          </div>
          <div class="signature-box">
            <div class="signature-line">Prepared By</div>
          </div>
          <div class="signature-box">
            <div class="signature-line">Authorized Signatory</div>
          </div>
        </div>

        <!-- Footer -->
        <div class="print-system-footer">
          <span>Printed: <%= new Date().toLocaleString() %></span>
          <span>Computer Generated Invoice - CarePoint Hospital</span>
          <span>Page 1 of 1</span>
        </div>

      </div>
    </div>
  </div>

</body>
</html>
