<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet">
  <link href="/css/print-docs.css" rel="stylesheet">
</head>
<body>

  <!-- Preview Toolbar -->
  <div class="no-print-bar">
    <div>
      <span class="fw-bold"><i class="fa-solid fa-file-invoice-dollar"></i> IPD Discharge Summary Preview</span>
      <small class="text-muted ms-2">A4 Optimized Layout</small>
    </div>
    <div>
      <button class="btn btn-outline-secondary btn-sm me-2" onclick="window.history.back()"><i class="fa-solid fa-arrow-left"></i> Back</button>
      <button class="btn btn-primary btn-sm" onclick="window.print()"><i class="fa-solid fa-print"></i> Print Document</button>
    </div>
  </div>

  <div class="document-preview-container">
    <div class="a4-document">
      <div class="hospital-watermark"><%= hospitalName %></div>
      <div class="doc-content">
        
        <!-- Header -->
        <div class="doc-header d-flex justify-content-between align-items-center">
          <div class="d-flex align-items-center">
            <div class="me-3">
              <i class="fa-solid fa-circle-h hospital-logo-icon"></i>
            </div>
            <div>
              <h1 class="hospital-title text-hospital-primary"><%= hospitalName %></h1>
              <p class="hospital-subtitle"><i class="fa-solid fa-location-dot"></i> Sector 62, Noida, Uttar Pradesh - 201301</p>
              <p class="hospital-subtitle"><i class="fa-solid fa-phone"></i> +91 95089 70151 | <i class="fa-solid fa-envelope"></i> contact@carepoint.local</p>
              <p class="hospital-subtitle"><i class="fa-solid fa-globe"></i> www.carepointhospital.local | IPD Services Division</p>
            </div>
          </div>
          <div class="text-end">
            <span class="doc-type-title">Discharge Summary</span>
            <div class="barcode-container">
              <div class="barcode-bars"></div>
              <div class="barcode-text">IPD<%= String(admission._id).slice(-6) %></div>
            </div>
          </div>
        </div>

        <!-- Meta Info -->
        <div class="row">
          <div class="col-6">
            <div class="meta-box">
              <div class="meta-title">Patient Demographics</div>
              <div class="meta-grid">
                <div class="meta-item"><span class="meta-label">Patient Name:</span><span class="meta-value"><%= admission.patient?.name %></span></div>
                <div class="meta-item"><span class="meta-label">Patient ID (UHID):</span><span class="meta-value"><%= admission.patient?.patientId || '-' %></span></div>
                <div class="meta-item"><span class="meta-label">Age / Gender:</span><span class="meta-value"><%= admission.patient ? (admission.patient.age || 'N/A') + ' yrs / ' + (admission.patient.gender || 'N/A') : '-' %></span></div>
                <div class="meta-item"><span class="meta-label">Blood Group:</span><span class="meta-value"><%= admission.patient?.bloodGroup || '-' %></span></div>
              </div>
            </div>
          </div>
          <div class="col-6">
            <div class="meta-box">
              <div class="meta-title">Admission & Ward Info</div>
              <div class="meta-grid">
                <div class="meta-item"><span class="meta-label">Assigned Doctor:</span><span class="meta-value"><%= admission.doctor?.name || '-' %></span></div>
                <div class="meta-item"><span class="meta-label">Admission Date:</span><span class="meta-value"><%= new Date(admission.admissionDate).toLocaleDateString() %></span></div>
                <div class="meta-item"><span class="meta-label">Discharge Date:</span><span class="meta-value"><%= admission.dischargeDate ? new Date(admission.dischargeDate).toLocaleDateString() : 'Active IPD' %></span></div>
                <div class="meta-item"><span class="meta-label">Ward / Bed / Room:</span><span class="meta-value"><%= admission.ward || 'A' %> / <%= admission.bedNumber %> / <%= admission.room?.roomNumber %></span></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Clinical details block -->
        <div class="row mt-3">
          <div class="col-12 mb-3">
            <div class="border p-3" style="border-radius: 8px;">
              <h6 class="text-hospital-primary fw-bold mb-2"><i class="fa-solid fa-notes-medical"></i> Primary Diagnosis</h6>
              <p class="mb-0 text-dark" style="font-size: 0.9rem; font-weight: 500;"><%= admission.patient?.disease || 'Acute Gastroenteritis with Severe Dehydration' %></p>
            </div>
          </div>

          <div class="col-12 mb-3">
            <div class="border p-3" style="border-radius: 8px;">
              <h6 class="text-hospital-primary fw-bold mb-2"><i class="fa-solid fa-procedures"></i> Treatment Summary & Course in Hospital</h6>
              <p class="mb-0 text-muted" style="font-size: 0.85rem; line-height: 1.6;">
                The patient was admitted with complaints of <%= admission.patient?.disease || 'acute illness' %>. Initial evaluation showed mild dehydration and electrolyte imbalance. Hydration was restored using IV fluids (NS, RL) and parentral anti-emetics. Patient showed satisfactory recovery and was mobilized soon. Vital parameters remained stable. At the time of discharge, patient is well hydrated, afebrile, and asymptomatic.
              </p>
            </div>
          </div>

          <div class="col-12 mb-3">
            <div class="border p-3" style="border-radius: 8px;">
              <h6 class="text-hospital-primary fw-bold mb-2"><i class="fa-solid fa-prescription-bottle-medical"></i> Discharge Medicines Advice</h6>
              <table class="table table-sm table-borderless mb-0 fs-7" style="font-size: 0.85rem;">
                <thead>
                  <tr class="border-bottom text-muted">
                    <th>Medicine Description</th>
                    <th>Frequency</th>
                    <th>Days</th>
                    <th>Instructions</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td class="fw-bold text-dark">Tab. Pantoprazole 40mg</td>
                    <td>1 - 0 - 0 (Once Daily)</td>
                    <td>5 Days</td>
                    <td>Before Breakfast</td>
                  </tr>
                  <tr>
                    <td class="fw-bold text-dark">Tab. Paracetamol 650mg</td>
                    <td>1 - 0 - 1 (Twice Daily)</td>
                    <td>3 Days</td>
                    <td>After Food</td>
                  </tr>
                  <tr>
                    <td class="fw-bold text-dark">Tab. Ofloxacin-Ornidazole</td>
                    <td>1 - 0 - 1 (Twice Daily)</td>
                    <td>5 Days</td>
                    <td>After Food</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>

          <div class="col-12 mb-3">
            <div class="border p-3" style="border-radius: 8px;">
              <h6 class="text-hospital-primary fw-bold mb-2"><i class="fa-solid fa-circle-exclamation"></i> Follow-up Advice & Emergency Instructions</h6>
              <p class="mb-0 text-muted" style="font-size: 0.85rem; line-height: 1.6;">
                Follow up in OPD after 7 days with <%= admission.doctor?.name || 'Dr. Asha Mehta' %>. In case of emergency (high fever, severe abdominal pain, persistent vomiting), please contact CarePoint Hospital Emergency helpline immediately (+91 95089 70151).
              </p>
            </div>
          </div>
        </div>

        <!-- Verification/Signatures -->
        <div class="doc-verification mt-5">
          <div class="signature-box">
            <div class="hospital-seal-box">IPD Seal</div>
            <div class="signature-line">Hospital Seal</div>
          </div>
          <div class="signature-box">
            <div class="signature-line">Resident Doctor</div>
          </div>
          <div class="signature-box">
            <div style="height: 35px; border-bottom: 1px dotted #adb5bd;" class="mb-1 text-muted text-center italic">Digitally Signed</div>
            <div class="signature-line">Attending Consultant</div>
          </div>
        </div>

        <!-- Footer System -->
        <div class="print-system-footer mt-5">
          <span>Printed: <%= new Date().toLocaleString() %></span>
          <span>CarePoint Hospital IPD Services Discharge summary</span>
          <span>Page 1 of 1</span>
        </div>

      </div>
    </div>
  </div>

</body>
</html>
