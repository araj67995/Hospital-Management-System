<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet">
  <link href="/css/print-docs.css" rel="stylesheet">
</head>
<body>

  <!-- Preview Toolbar -->
  <div class="no-print-bar">
    <div>
      <span class="fw-bold"><i class="fa-solid fa-file-prescription"></i> Doctor Prescription Preview</span>
      <small class="text-muted ms-2">A4 Optimized Layout</small>
    </div>
    <div>
      <button class="btn btn-outline-secondary btn-sm me-2" onclick="window.history.back()"><i class="fa-solid fa-arrow-left"></i> Back</button>
      <button class="btn btn-primary btn-sm" onclick="window.print()"><i class="fa-solid fa-print"></i> Print Document</button>
    </div>
  </div>

  <div class="document-preview-container">
    <div class="a4-document">
      <div class="hospital-watermark"><%= hospitalName %></div>
      <div class="doc-content">
        
        <!-- Header -->
        <div class="doc-header d-flex justify-content-between align-items-center">
          <div class="d-flex align-items-center">
            <div class="me-3">
              <i class="fa-solid fa-circle-h hospital-logo-icon"></i>
            </div>
            <div>
              <h1 class="hospital-title text-hospital-primary"><%= hospitalName %></h1>
              <p class="hospital-subtitle"><i class="fa-solid fa-location-dot"></i> Sector 62, Noida, Uttar Pradesh - 201301</p>
              <p class="hospital-subtitle"><i class="fa-solid fa-phone"></i> +91 95089 70151 | <i class="fa-solid fa-envelope"></i> doctor@carepoint.local</p>
              <p class="hospital-subtitle"><i class="fa-solid fa-globe"></i> www.carepointhospital.local</p>
            </div>
          </div>
          <div class="text-end">
            <span class="doc-type-title">Doctor Prescription</span>
            <div class="barcode-container">
              <div class="barcode-bars"></div>
              <div class="barcode-text">RX<%= String(prescription._id).slice(-6) %></div>
            </div>
          </div>
        </div>

        <!-- Meta Info -->
        <div class="row">
          <div class="col-6">
            <div class="meta-box">
              <div class="meta-title">Patient Details</div>
              <div class="meta-grid">
                <div class="meta-item"><span class="meta-label">Patient Name:</span><span class="meta-value"><%= prescription.patient?.name %></span></div>
                <div class="meta-item"><span class="meta-label">Patient ID (UHID):</span><span class="meta-value"><%= prescription.patient?.patientId || '-' %></span></div>
                <div class="meta-item"><span class="meta-label">Age / Gender:</span><span class="meta-value"><%= prescription.patient ? (prescription.patient.age || 'N/A') + ' yrs / ' + (prescription.patient.gender || 'N/A') : '-' %></span></div>
                <div class="meta-item"><span class="meta-label">Mobile Number:</span><span class="meta-value"><%= prescription.patient?.mobile || '-' %></span></div>
              </div>
            </div>
          </div>
          <div class="col-6">
            <div class="meta-box">
              <div class="meta-title">Consultation Information</div>
              <div class="meta-grid">
                <div class="meta-item"><span class="meta-label">Doctor Name:</span><span class="meta-value"><%= prescription.doctor?.name %></span></div>
                <div class="meta-item"><span class="meta-label">Specialization:</span><span class="meta-value"><%= prescription.doctor?.specialization || '-' %></span></div>
                <div class="meta-item"><span class="meta-label">Date:</span><span class="meta-value"><%= new Date(prescription.createdAt).toLocaleDateString() %></span></div>
                <div class="meta-item"><span class="meta-label">Appointment No:</span><span class="meta-value"><%= prescription.appointment?.appointmentNo || '-' %></span></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Diagnosis Summary -->
        <div class="card border p-3 mb-4" style="border-radius: 10px; background-color: #fbfbfb;">
          <h6 class="text-hospital-primary fw-bold mb-1"><i class="fa-solid fa-notes-medical"></i> Diagnosis Summary</h6>
          <p class="mb-0 text-dark fw-bold" style="font-size: 0.9rem;">
            <%= prescription.diagnosis || 'General Checkup' %>
          </p>
        </div>

        <!-- Rx Symbol -->
        <div class="rx-symbol">R<sub>x</sub></div>

        <!-- Prescription Medicines Table -->
        <table class="table hospital-table align-middle">
          <thead>
            <tr>
              <th style="width: 5%">#</th>
              <th>Medicine Description</th>
              <th class="text-center" style="width: 25%">Schedule (M-A-N)</th>
              <th class="text-center" style="width: 10%">Days</th>
              <th>Instructions</th>
            </tr>
          </thead>
          <tbody>
            <% (prescription.medicines || []).forEach((med, index) => { %>
              <tr>
                <td><%= index + 1 %></td>
                <td>
                  <div class="fw-bold text-dark"><%= med.name %></div>
                  <div class="text-muted small"><%= med.dosage || '' %> (<%= med.unit || 'Tablet' %>)</div>
                </td>
                <td class="text-center">
                  <span class="badge text-bg-light border px-2 py-1 mx-1"><%= med.morning ? '1' : '0' %></span>-
                  <span class="badge text-bg-light border px-2 py-1 mx-1"><%= med.afternoon ? '1' : '0' %></span>-
                  <span class="badge text-bg-light border px-2 py-1 mx-1"><%= med.night ? '1' : '0' %></span>
                </td>
                <td class="text-center fw-bold"><%= med.days || '-' %></td>
                <td><span class="text-muted"><%= med.instructions || 'As advised' %></span></td>
              </tr>
            <% }) %>
          </tbody>
        </table>

        <!-- Medical Notes -->
        <% if (prescription.notes) { %>
          <div class="card border p-3 mb-4 mt-4" style="border-radius: 10px; background-color: #ffffff;">
            <h6 class="text-hospital-primary fw-bold mb-2"><i class="fa-solid fa-comment-dots"></i> Doctor Remarks & Advice</h6>
            <p class="mb-0 text-dark fs-7" style="font-size: 0.85rem; line-height: 1.5;">
              <%= prescription.notes %>
            </p>
          </div>
        <% } %>

        <!-- Verification/Signatures -->
        <div class="doc-verification mt-5">
          <div class="signature-box">
            <div class="hospital-seal-box">OPD Seal</div>
            <div class="signature-line">Hospital Seal</div>
          </div>
          <div class="signature-box text-center">
            <div class="qr-container mb-2">
              <img class="qr-image" src="https://api.qrserver.com/v1/create-qr-code/?size=70x70&data=<%= encodeURIComponent('RX: ' + prescription._id + ', Doctor: ' + prescription.doctor?.name) %>" alt="QR Code" width="70" height="70">
            </div>
            <span class="small text-muted">Scan to Verify</span>
          </div>
          <div class="signature-box">
            <div style="height: 35px; border-bottom: 1px dotted #adb5bd;" class="mb-1 text-muted text-center italic">Digitally Signed</div>
            <div class="signature-line"><%= prescription.doctor?.name %></div>
          </div>
        </div>

        <!-- Footer System -->
        <div class="print-system-footer mt-5">
          <span>Printed: <%= new Date().toLocaleString() %></span>
          <span>CarePoint Hospital Prescription Services</span>
          <span>Page 1 of 1</span>
        </div>

      </div>
    </div>
  </div>

</body>
</html>
