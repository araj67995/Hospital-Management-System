<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet">
  <link href="/css/print-docs.css" rel="stylesheet">
</head>
<body>

  <!-- Preview Toolbar -->
  <div class="no-print-bar">
    <div>
      <span class="fw-bold"><i class="fa-solid fa-flask"></i> Lab Diagnostic Report Preview</span>
      <small class="text-muted ms-2">A4 Optimized Layout</small>
    </div>
    <div>
      <button class="btn btn-outline-secondary btn-sm me-2" onclick="window.history.back()"><i class="fa-solid fa-arrow-left"></i> Back</button>
      <button class="btn btn-primary btn-sm" onclick="window.print()"><i class="fa-solid fa-print"></i> Print Document</button>
    </div>
  </div>

  <div class="document-preview-container">
    <div class="a4-document">
      <div class="hospital-watermark"><%= hospitalName %></div>
      <div class="doc-content">
        
        <!-- Header -->
        <div class="doc-header d-flex justify-content-between align-items-center">
          <div class="d-flex align-items-center">
            <div class="me-3">
              <i class="fa-solid fa-circle-h hospital-logo-icon"></i>
            </div>
            <div>
              <h1 class="hospital-title text-hospital-primary"><%= hospitalName %></h1>
              <p class="hospital-subtitle"><i class="fa-solid fa-location-dot"></i> Sector 62, Noida, Uttar Pradesh - 201301</p>
              <p class="hospital-subtitle"><i class="fa-solid fa-phone"></i> +91 95089 70151 | <i class="fa-solid fa-envelope"></i> lab@carepoint.local</p>
              <p class="hospital-subtitle"><i class="fa-solid fa-globe"></i> www.carepointhospital.local | Accredited NABL Lab</p>
            </div>
          </div>
          <div class="text-end">
            <span class="doc-type-title">Lab Diagnostic Report</span>
            <div class="barcode-container">
              <div class="barcode-bars"></div>
              <div class="barcode-text">LAB<%= String(report._id).slice(-6) %></div>
            </div>
          </div>
        </div>

        <!-- Meta Info -->
        <div class="row">
          <div class="col-6">
            <div class="meta-box">
              <div class="meta-title">Patient Details</div>
              <div class="meta-grid">
                <div class="meta-item"><span class="meta-label">Patient Name:</span><span class="meta-value"><%= report.patient?.name %></span></div>
                <div class="meta-item"><span class="meta-label">Patient ID (UHID):</span><span class="meta-value"><%= report.patient?.patientId || '-' %></span></div>
                <div class="meta-item"><span class="meta-label">Age / Gender:</span><span class="meta-value"><%= report.patient ? (report.patient.age || 'N/A') + ' yrs / ' + (report.patient.gender || 'N/A') : '-' %></span></div>
                <div class="meta-item"><span class="meta-label">Mobile Number:</span><span class="meta-value"><%= report.patient?.mobile || '-' %></span></div>
              </div>
            </div>
          </div>
          <div class="col-6">
            <div class="meta-box">
              <div class="meta-title">Diagnostic Information</div>
              <div class="meta-grid">
                <div class="meta-item"><span class="meta-label">Referral Doctor:</span><span class="meta-value"><%= report.doctor?.name || 'Self Referral' %></span></div>
                <div class="meta-item"><span class="meta-label">Report Date:</span><span class="meta-value"><%= new Date(report.createdAt).toLocaleDateString() %></span></div>
                <div class="meta-item"><span class="meta-label">Report Type:</span><span class="meta-value"><%= report.reportType %></span></div>
                <div class="meta-item"><span class="meta-label">Lab Reference ID:</span><span class="meta-value">REF-<%= String(report._id).slice(-5).toUpperCase() %></span></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Test Name Banner -->
        <div class="bg-hospital-light p-2 mb-3 border text-center" style="border-radius: 6px;">
          <h5 class="fw-bold mb-0 text-hospital-primary"><%= report.title %></h5>
        </div>

        <!-- Test Results Table -->
        <table class="table hospital-table align-middle">
          <thead>
            <tr>
              <th style="width: 5%">S.No</th>
              <th>Test Parameter Name</th>
              <th class="text-center" style="width: 18%">Observed Value</th>
              <th class="text-center" style="width: 15%">Unit</th>
              <th class="text-center" style="width: 25%">Reference Interval</th>
              <th class="text-center" style="width: 10%">Status</th>
            </tr>
          </thead>
          <tbody>
            <% if (report.reportType === 'Blood Test') { %>
              <tr>
                <td>1</td>
                <td class="fw-bold">Hemoglobin (Hb)</td>
                <td class="text-center fw-bold">14.2</td>
                <td class="text-center">g/dL</td>
                <td class="text-center">13.0 - 17.0</td>
                <td class="text-center"><span class="badge bg-success">Normal</span></td>
              </tr>
              <tr>
                <td>2</td>
                <td class="fw-bold">Total WBC Count (TLC)</td>
                <td class="text-center fw-bold text-danger">11,500</td>
                <td class="text-center">/cumm</td>
                <td class="text-center">4,000 - 11,000</td>
                <td class="text-center"><span class="badge bg-danger">High</span></td>
              </tr>
              <tr>
                <td>3</td>
                <td class="fw-bold">Platelet Count</td>
                <td class="text-center fw-bold">2.40</td>
                <td class="text-center">Lakhs/cumm</td>
                <td class="text-center">1.50 - 4.50</td>
                <td class="text-center"><span class="badge bg-success">Normal</span></td>
              </tr>
              <tr>
                <td>4</td>
                <td class="fw-bold">Random Blood Sugar (RBS)</td>
                <td class="text-center fw-bold">110</td>
                <td class="text-center">mg/dL</td>
                <td class="text-center">70 - 140</td>
                <td class="text-center"><span class="badge bg-success">Normal</span></td>
              </tr>
            <% } else if (report.reportType === 'ECG') { %>
              <tr>
                <td>1</td>
                <td class="fw-bold">Heart Rate</td>
                <td class="text-center fw-bold">78</td>
                <td class="text-center">bpm</td>
                <td class="text-center">60 - 100</td>
                <td class="text-center"><span class="badge bg-success">Normal</span></td>
              </tr>
              <tr>
                <td>2</td>
                <td class="fw-bold">PR Interval</td>
                <td class="text-center fw-bold">0.16</td>
                <td class="text-center">sec</td>
                <td class="text-center">0.12 - 0.20</td>
                <td class="text-center"><span class="badge bg-success">Normal</span></td>
              </tr>
              <tr>
                <td>3</td>
                <td class="fw-bold">QRS Duration</td>
                <td class="text-center fw-bold text-danger">0.12</td>
                <td class="text-center">sec</td>
                <td class="text-center">0.06 - 0.10</td>
                <td class="text-center"><span class="badge bg-danger">Borderline</span></td>
              </tr>
              <tr>
                <td>4</td>
                <td class="fw-bold">QT Interval</td>
                <td class="text-center fw-bold">0.38</td>
                <td class="text-center">sec</td>
                <td class="text-center">0.35 - 0.44</td>
                <td class="text-center"><span class="badge bg-success">Normal</span></td>
              </tr>
            <% } else { %>
              <tr>
                <td>1</td>
                <td class="fw-bold">Diagnostic Evaluation</td>
                <td class="text-center fw-bold">Satisfactory</td>
                <td class="text-center">-</td>
                <td class="text-center">Normal / Negative</td>
                <td class="text-center"><span class="badge bg-success">Normal</span></td>
              </tr>
            <% } %>
          </tbody>
        </table>

        <!-- Doctor Remarks -->
        <div class="card border p-3 mb-4" style="border-radius: 10px; background-color: #fbfbfb;">
          <h6 class="text-hospital-primary fw-bold mb-2"><i class="fa-solid fa-comment-medical"></i> Pathologist Notes & Remarks</h6>
          <p class="mb-0 text-dark fs-7" style="font-size: 0.85rem; line-height: 1.5;">
            <%= report.notes || 'The observed diagnostic values are satisfying clinical ranges. Kindly correlate with patient\'s exact symptomatic history.' %>
          </p>
        </div>

        <!-- Verification/Signatures -->
        <div class="doc-verification mt-5">
          <div class="signature-box">
            <div class="hospital-seal-box">Lab Seal</div>
            <div class="signature-line">Diagnostic Lab Seal</div>
          </div>
          <div class="signature-box">
            <div style="height: 35px; border-bottom: 1px dotted #adb5bd;" class="mb-1 text-muted text-center italic">Digitally Signed</div>
            <div class="signature-line">Lab Technician</div>
          </div>
          <div class="signature-box">
            <div style="height: 35px; border-bottom: 1px dotted #adb5bd;" class="mb-1 text-muted text-center italic">Dr. K. Saxena, MD</div>
            <div class="signature-line">Consultant Pathologist</div>
          </div>
        </div>

        <!-- Footer System -->
        <div class="print-system-footer mt-5">
          <span>Printed: <%= new Date().toLocaleString() %></span>
          <span>CarePoint Hospital Pathology Division</span>
          <span>Page 1 of 1</span>
        </div>

      </div>
    </div>
  </div>

</body>
</html>
