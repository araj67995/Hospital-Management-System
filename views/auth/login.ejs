<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Login | <%= hospitalName %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body class="login-body">
  <section class="login-card">
    <div class="login-mark"><i class="fa-solid fa-staff-snake"></i></div>
    <h1><%= hospitalName %></h1>
    <% if (error && error.length) { %><div class="alert alert-danger"><%= error[0] %></div><% } %>
    <% if (success && success.length) { %><div class="alert alert-success"><%= success[0] %></div><% } %>
    <form method="post" action="/login" class="needs-validation" novalidate>
      <label class="form-label">Email</label>
      <input class="form-control" type="email" name="email" required>
      <label class="form-label mt-3">Password</label>
      <input class="form-control" type="password" name="password" required>
      <button class="btn btn-primary w-100 mt-4"><i class="fa-solid fa-right-to-bracket"></i> Login</button>
    </form>
    <p class="text-center mt-3 mb-0">New patient? <a href="/register">Create account</a></p>
  </section>
  <script src="/js/app.js"></script>
</body>
</html>
