<aside class="sidebar">
  <a class="brand" href="<%= currentUser ? '/' + currentUser.role : '/login' %>">
    <i class="fa-solid fa-staff-snake"></i>
    <strong><%= hospitalName %></strong>
  </a>
  <% if (currentUser && currentUser.role === 'admin') { %>
    <nav>
      <a href="/admin"><i class="fa-solid fa-chart-line"></i> Dashboard</a>
      <a href="/admin/doctors"><i class="fa-solid fa-user-doctor"></i> Doctors</a>
      <a href="/admin/patients"><i class="fa-solid fa-bed-pulse"></i> Patients</a>
      <a href="/admin/receptionists"><i class="fa-solid fa-headset"></i> Receptionists</a>
      <a href="/admin/departments"><i class="fa-solid fa-building"></i> Departments</a>
      <a href="/admin/rooms"><i class="fa-solid fa-door-open"></i> Rooms</a>
      <a href="/admin/medicines"><i class="fa-solid fa-pills"></i> Medicines</a>
      <a href="/admin/appointments"><i class="fa-solid fa-calendar-check"></i> Appointments</a>
      <a href="/admin/bills"><i class="fa-solid fa-file-invoice-dollar"></i> Billing</a>
      <a href="/admin/reports"><i class="fa-solid fa-file-medical"></i> Reports</a>
      <a href="/admin/settings"><i class="fa-solid fa-gear"></i> Settings</a>
    </nav>
  <% } else if (currentUser && currentUser.role === 'doctor') { %>
    <nav>
      <a href="/doctor"><i class="fa-solid fa-chart-simple"></i> Dashboard</a>
      <a href="/doctor/appointments"><i class="fa-solid fa-calendar-day"></i> Appointments</a>
      <a href="/doctor/patients"><i class="fa-solid fa-hospital-user"></i> Patients</a>
      <a href="/doctor/prescriptions"><i class="fa-solid fa-prescription"></i> Prescriptions</a>
      <a href="/doctor/reports"><i class="fa-solid fa-upload"></i> Reports</a>
      <a href="/doctor/schedule"><i class="fa-solid fa-clock"></i> Schedule</a>
    </nav>
  <% } else if (currentUser && currentUser.role === 'receptionist') { %>
    <nav>
      <a href="/receptionist"><i class="fa-solid fa-chart-simple"></i> Dashboard</a>
      <a href="/receptionist/patients"><i class="fa-solid fa-user-plus"></i> Patients</a>
      <a href="/receptionist/appointments"><i class="fa-solid fa-calendar-plus"></i> Appointments</a>
      <a href="/receptionist/admissions"><i class="fa-solid fa-procedures"></i> Admissions</a>
      <a href="/receptionist/bills"><i class="fa-solid fa-receipt"></i> Billing</a>
      <a href="/receptionist/search"><i class="fa-solid fa-magnifying-glass"></i> Search</a>
    </nav>
  <% } else if (currentUser && currentUser.role === 'patient') { %>
    <nav>
      <a href="/patient"><i class="fa-solid fa-chart-simple"></i> Dashboard</a>
      <a href="/patient/profile"><i class="fa-solid fa-id-card"></i> Profile</a>
      <a href="/patient/appointments"><i class="fa-solid fa-calendar-check"></i> Appointments</a>
      <a href="/patient/appointments/new"><i class="fa-solid fa-calendar-plus"></i> Book Appointment</a>
      <a href="/patient/prescriptions"><i class="fa-solid fa-prescription-bottle-medical"></i> Prescriptions</a>
      <a href="/patient/reports"><i class="fa-solid fa-file-medical"></i> Reports</a>
      <a href="/patient/bills"><i class="fa-solid fa-download"></i> Bills</a>
    </nav>
  <% } %>
</aside>
